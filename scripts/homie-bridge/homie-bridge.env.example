# BOOM × Homie bridge — configurazione
# Copia questo file in `homie-bridge.env` e compila. NON committare il file reale:
#   cp homie-bridge.env.example homie-bridge.env
#
# HOMIE_SECRET deve essere identico al valore HOMIE_SECRET impostato su Vercel
# (lo stesso che usano /api/homie/inbound e tutta l'API /api/agent/*).

HOMIE_SECRET=
BOOM_BASE_URL=https://boomrome.com
HB_INTERVAL=30
HB_MODEL=claude
HB_VERSION=mac-bridge/1.0
