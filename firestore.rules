rules_version = '2';

// BOOM Roma — Firestore Security Rules
// Tuned to the real schema used by portal.html (verified field names):
//   properties.ownerId, properties.currentContractId
//   contracts.tenantId, contracts.propertyId, contracts.{tenant,landlord}SignToken
//   payments.tenantId, payments.propertyId, payments.contractId
//   maintenance.userId (tenant uid), maintenance.propertyId
//   documents.userId, documents.shared, documents.propertyId
//   notifications.userId
//   users.role ∈ {admin, landlord, tenant}
//
// Model: admin = full access. Landlord = only their own properties and the
// contracts/payments/maintenance/documents attached to them. Tenant = only
// their own contract, payments, maintenance, documents. Everything in the
// lead / PFS / ops layer is admin-only. Anonymous sessions exist solely for
// the Magic Sign flow (sign a contract by single-use token).
//
// IMPORTANT: portal.html's loadDataFresh() currently issues unconstrained
// collection .get() calls. Those succeed for admins (every doc allowed) but
// Firestore will REJECT them for landlord/tenant unless the query carries a
// matching where() clause. Deploy these rules together with the
// role-scoped query refactor, or non-admin logins will see empty data.

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ──────────────────────────────────────────────────────
    function isSignedIn() { return request.auth != null; }
    function uid()        { return request.auth.uid; }
    function userDoc()    { return get(/databases/$(database)/documents/users/$(uid())).data; }
    function role()       { return isSignedIn() ? userDoc().role : ''; }
    function isAdmin()    { return isSignedIn() && role() == 'admin'; }
    function isLandlord() { return isSignedIn() && role() == 'landlord'; }
    function isTenant()   { return isSignedIn() && role() == 'tenant'; }
    function isAnon()     { return isSignedIn() && request.auth.token.firebase.sign_in_provider == 'anonymous'; }

    function propertyData(pid) {
      return get(/databases/$(database)/documents/properties/$(pid)).data;
    }
    function contractData(cid) {
      return get(/databases/$(database)/documents/contracts/$(cid)).data;
    }
    // True if the signed-in landlord owns property `pid`.
    function ownsProperty(pid) {
      return isLandlord() && propertyData(pid).ownerId == uid();
    }
    // Only the listed fields changed in this write.
    function onlyChanges(allowed) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowed);
    }

    // ─── users ────────────────────────────────────────────────────────
    // Own doc readable; admins read all. Self-update cannot touch `role`.
    match /users/{userId} {
      allow read:   if isAdmin() || uid() == userId;
      allow create: if isAdmin();
      allow update: if isAdmin()
                    || (uid() == userId
                        && !('role' in request.resource.data.diff(resource.data).affectedKeys()));
      allow delete: if isAdmin();
    }

    // ─── properties ───────────────────────────────────────────────────
    // Admin: all. Landlord: own. Tenant: the one they currently rent
    // (verified via the property's currentContractId → contract.tenantId).
    match /properties/{propId} {
      allow read: if isAdmin()
                  || (isLandlord() && resource.data.ownerId == uid())
                  || (isTenant()
                      && resource.data.currentContractId != null
                      && contractData(resource.data.currentContractId).tenantId == uid());
      allow create, update, delete: if isAdmin();
    }

    // ─── contracts ────────────────────────────────────────────────────
    // Admin: all. Landlord: contracts on properties they own. Tenant: own.
    // Anonymous Magic-Sign session: read nothing here (token lookup is a
    // collection query — handle that via a constrained query the rule below
    // permits only when the token matches). Tenant may write ONLY their
    // signature fields.
    match /contracts/{cId} {
      allow read: if isAdmin()
                  || (isTenant() && resource.data.tenantId == uid())
                  || (isLandlord() && ownsProperty(resource.data.propertyId));
      allow create, delete: if isAdmin();
      // Admin full update; tenant may sign their own contract only.
      allow update: if isAdmin()
                    || (isTenant() && resource.data.tenantId == uid()
                        && onlyChanges(['tenantSignature','tenantSignedAt','tenantSignIP',
                                        'tenantSignUA','tenantSignToken','tenantSignedStatus']));
    }

    // ─── payments ─────────────────────────────────────────────────────
    // Admin write. Tenant reads own + may flag a payment as reported
    // (restricted field set). Landlord reads payments for owned properties.
    match /payments/{pId} {
      allow read: if isAdmin()
                  || (isTenant() && resource.data.tenantId == uid())
                  || (isLandlord() && resource.data.propertyId != null
                      && ownsProperty(resource.data.propertyId));
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
                    || (isTenant() && resource.data.tenantId == uid()
                        && onlyChanges(['tenantReported','tenantReportedAt','tenantReportDate',
                                        'tenantNotes','proofUrl','proofName']));
    }

    // ─── maintenance ──────────────────────────────────────────────────
    // Tenant: create + read own (userId == uid). Landlord: read for owned
    // properties. Admin: full (status changes, comments).
    match /maintenance/{mId} {
      allow read:   if isAdmin()
                    || (isTenant() && resource.data.userId == uid())
                    || (isLandlord() && resource.data.propertyId != null
                        && ownsProperty(resource.data.propertyId));
      allow create: if isSignedIn() && request.resource.data.userId == uid();
      allow update, delete: if isAdmin();
    }

    // ─── documents ────────────────────────────────────────────────────
    // Own docs always; shared docs visible to the property's landlord or
    // its current tenant. Users manage their own uploads; admin manages all.
    match /documents/{dId} {
      allow read: if isAdmin()
                  || resource.data.userId == uid()
                  || (resource.data.shared == true && resource.data.propertyId != null
                      && (ownsProperty(resource.data.propertyId)
                          || (isTenant()
                              && propertyData(resource.data.propertyId).currentContractId != null
                              && contractData(propertyData(resource.data.propertyId).currentContractId).tenantId == uid())));
      allow create: if isSignedIn() && request.resource.data.userId == uid();
      allow update, delete: if isAdmin() || resource.data.userId == uid();
    }

    // ─── notifications ────────────────────────────────────────────────
    // Per-user. Anyone signed-in may create one (tenant notifies admin /
    // landlord of a reported payment, maintenance request, etc.).
    match /notifications/{nId} {
      allow read, update, delete: if isAdmin() || resource.data.userId == uid();
      allow create: if isSignedIn();
    }

    // ─── magicLinks ───────────────────────────────────────────────────
    // Anonymous Magic-Sign session reads its token doc and flips used=true
    // exactly once. Admin manages.
    match /magicLinks/{tId} {
      allow read:   if isAdmin() || isAnon();
      allow create: if isAdmin();
      allow update: if isAnon()
                    && resource.data.used == false
                    && request.resource.data.used == true
                    && onlyChanges(['used','usedAt']);
      allow delete: if isAdmin();
    }

    // ─── invoices ─────────────────────────────────────────────────────
    match /invoices/{x} {
      allow read:  if isAdmin() || resource.data.recipientId == uid();
      allow write: if isAdmin();
    }

    // ─── viewingRequests ──────────────────────────────────────────────
    // Public booking forms POST here (anonymous create allowed). Reads
    // and management are admin-only.
    match /viewingRequests/{x} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // ─── config ───────────────────────────────────────────────────────
    // Protects the parse-docs bearer token (config/parse_docs).
    match /config/{x} { allow read, write: if isAdmin(); }

    // ─── activityLog ──────────────────────────────────────────────────
    // Append-only audit trail. Anyone signed-in appends; nobody edits.
    match /activityLog/{x} {
      allow read:   if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // ─── documentShares ───────────────────────────────────────────────
    // Share links handed to a commercialista. Created by admin or by the
    // landlord who owns the bundle; the public read path goes through
    // /api/share/lookup under admin creds, so anonymous has no direct
    // access here. ownerId = the landlord whose docs are shared.
    match /documentShares/{shareId} {
      allow read:   if isAdmin() || (isLandlord() && resource.data.ownerId == uid());
      allow create: if isAdmin() || (isLandlord() && request.resource.data.ownerId == uid());
      allow update, delete: if isAdmin() || (isLandlord() && resource.data.ownerId == uid());
    }

    // ─── taxPacks ─────────────────────────────────────────────────────
    // Metadata for a generated tax bundle (property + fiscal year + manifest).
    match /taxPacks/{packId} {
      allow read:   if isAdmin() || (isLandlord() && resource.data.ownerId == uid());
      allow create: if isAdmin() || (isLandlord() && request.resource.data.ownerId == uid());
      allow update, delete: if isAdmin() || (isLandlord() && resource.data.ownerId == uid());
    }

    // ─── Admin-only operational collections ───────────────────────────
    match /leads/{x}                      { allow read, write: if isAdmin(); }
    match /pfsClients/{x}                  { allow read, write: if isAdmin(); }
    match /pfsProperties/{x}               { allow read, write: if isAdmin(); }
    match /pfsActivities/{x}               { allow read, write: if isAdmin(); }
    match /landlords/{x}                   { allow read, write: if isAdmin(); }
    match /clients/{x}                     { allow read, write: if isAdmin(); }
    match /action_queue/{x}                { allow read, write: if isAdmin(); }
    match /signRequests/{x}                { allow read, write: if isAdmin(); }
    match /rules/{x}                       { allow read, write: if isAdmin(); }
    match /ruleExecutions/{x}              { allow read, write: if isAdmin(); }
    match /deadlines/{x}                   { allow read, write: if isAdmin(); }
    match /tasks/{x}                       { allow read, write: if isAdmin(); }
    match /listings/{x}                    { allow read, write: if isAdmin(); }
    match /settings/{x}                    { allow read, write: if isAdmin(); }
    match /radarSearches/{x}               { allow read, write: if isAdmin(); }
    match /preProperties/{x}               { allow read, write: if isAdmin(); }
    match /ziShortlists/{x}                { allow read, write: if isAdmin(); }
    match /contractRegistrations/{x}       { allow read, write: if isAdmin(); }
    match /contractRegistrationStatus/{x}  { allow read, write: if isAdmin(); }
    match /messageLog/{x}                  { allow read: if isAdmin(); allow write: if false; }

    // ─── Default deny ─────────────────────────────────────────────────
    // Any collection not matched above is locked. Add an explicit block
    // before shipping a new collection.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
