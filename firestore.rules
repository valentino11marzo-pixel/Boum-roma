rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────
// BOOM Firestore security rules — version-controlled so a change to the
// public catalog can never again silently take production down without a
// git trail.
//
// Deploy with:   firebase deploy --only firestore:rules
// (run from the repo root, logged in to project `boom-property-dashboards`)
//
// The website reads `listings` (and `settings`) UNAUTHENTICATED from the
// browser. Those two collections must stay publicly readable. Everything
// else (leads, viewingRequests, action_queue, owners, …) stays private.
// Writes never allow anonymous sessions, so enabling Anonymous Auth for the
// public site can't be abused to mutate private data.
// ─────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    function isStaff() {
      return request.auth != null
        && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    // PUBLIC CATALOG — the public site reads these without logging in.
    match /listings/{id} {
      allow read: if true;
      allow write: if isStaff();
    }

    // Small public config the homepage/showcase reads (e.g. settings/video).
    match /settings/{doc} {
      allow read: if true;
      allow write: if isStaff();
    }

    // EVERYTHING ELSE — private. Authenticated staff only, never anonymous.
    // Tighten further to a specific admin UID/claim if you add non-staff users.
    match /{document=**} {
      allow read, write: if isStaff();
    }
  }
}
