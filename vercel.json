{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/index.html", "destination": "/", "permanent": true },
    { "source": "/apartments.html", "destination": "/apartments", "permanent": true },
    { "source": "/about.html", "destination": "/about", "permanent": true },
    { "source": "/contact.html", "destination": "/contact", "permanent": true },
    { "source": "/faq.html", "destination": "/faq", "permanent": true },
    { "source": "/how-it-works.html", "destination": "/how-it-works", "permanent": true },
    { "source": "/book.html", "destination": "/book", "permanent": true },
    { "source": "/concierge.html", "destination": "/concierge", "permanent": true },
    { "source": "/blog.html", "destination": "/blog", "permanent": true },
    { "source": "/owners.html", "destination": "/owners", "permanent": true },
    { "source": "/deals.html", "destination": "/deals", "permanent": true },
