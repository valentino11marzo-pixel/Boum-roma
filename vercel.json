    { "source": "/virtual-viewing.html", "destination": "/virtual-viewing", "permanent": true },
    { "source": "/deal-assistance.html", "destination": "/deal-assistance", "permanent": true },
    { "source": "/privacy.html", "destination": "/privacy", "permanent": true },
    { "source": "/terms.html", "destination": "/terms", "permanent": true },
    { "source": "/apartment_navona.html", "destination": "/listing/navona", "permanent": true },
    { "source": "/apartment_ripetta.html", "destination": "/listing/ripetta", "permanent": true },
    { "source": "/apartment_pigneto.html", "destination": "/listing/pigneto", "permanent": true },
    { "source": "/apartment_angelico.html", "destination": "/listing/angelico", "permanent": true },
    { "source": "/apartment_levico.html", "destination": "/listing/levico", "permanent": true },
    { "source": "/apartment_piemonte.html", "destination": "/listing/piemonte", "permanent": true },
    { "source": "/apartment-marconi.html", "destination": "/listing/marconi", "permanent": true },
    { "source": "/apartment-navona", "destination": "/listing/navona", "permanent": true },
    { "source": "/apartment-ripetta", "destination": "/listing/ripetta", "permanent": true },
    { "source": "/apartment-pigneto", "destination": "/listing/pigneto", "permanent": true },
    { "source": "/apartment-angelico", "destination": "/listing/angelico", "permanent": true },
    { "source": "/apartment-levico", "destination": "/listing/levico", "permanent": true },
    { "source": "/apartment-piemonte", "destination": "/listing/piemonte", "permanent": true },
    { "source": "/apartment-marconi", "destination": "/listing/marconi", "permanent": true },
    { "source": "/faq_page.html", "destination": "/faq", "permanent": true },
    { "source": "/faq-page", "destination": "/faq", "permanent": true }
  ],
  "rewrites": [
    { "source": "/listing/:id", "destination": "/api/listing" },
    { "source": "/listings-sitemap.xml", "destination": "/api/sitemap-listings" },
    { "source": "/book", "destination": "/book.html" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/contact", "destination": "/contact.html" },
    { "source": "/login", "destination": "/login.html" },
    { "source": "/sign", "destination": "/sign.html" },
    { "source": "/portal", "destination": "/portal.html" },
    { "source": "/owners", "destination": "/owners.html" },
    { "source": "/deals", "destination": "/deals.html" },
    { "source": "/blog", "destination": "/blog.html" },
    { "source": "/faq", "destination": "/faq.html" },
    { "source": "/concierge", "destination": "/concierge.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/how-it-works", "destination": "/how-it-works.html" },
    { "source": "/booking", "destination": "/booking.html" },
    { "source": "/onboarding", "destination": "/onboarding.html" },
    { "source": "/tenant", "destination": "/tenant.html" },
    { "source": "/tenant-registration", "destination": "/tenant-registration.html" },
    { "source": "/proppass", "destination": "/proppass.html" },
    { "source": "/pass-delivery", "destination": "/pass-delivery.html" },
    { "source": "/apartment-detail", "destination": "/apartment-detail.html" },
    { "source": "/virtual-viewing", "destination": "/virtual-viewing.html" },
    { "source": "/pre-arrival", "destination": "/pre-arrival.html" },
    { "source": "/deal-assistance", "destination": "/deal-assistance.html" },
    { "source": "/client-portal", "destination": "/client-portal.html" },
    { "source": "/share", "destination": "/share.html" },
    { "source": "/property-finding", "destination": "/property-finding.html" },
    { "source": "/dashboard", "destination": "/dashboard.html" },
    { "source": "/thank-you", "destination": "/thank-you.html" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/admin-flats", "destination": "/admin-flats.html" },
    { "source": "/owner", "destination": "/owner.html" },
    { "source": "/owner-dashboard", "destination": "/owner-dashboard.html" },
    { "source": "/form-tenant", "destination": "/form-tenant.html" },
    { "source": "/form-landlord", "destination": "/form-landlord.html" },
    { "source": "/precheck", "destination": "/precheck.html" },
    { "source": "/seed-listings", "destination": "/seed-listings.html" },
    { "source": "/setup-firebase", "destination": "/setup-firebase.html" },
    { "source": "/boom-doc-parser", "destination": "/boom_doc_parser.html" },
    { "source": "/cockpit-preview", "destination": "/cockpit-preview.html" },
    { "source": "/pfs-command", "destination": "/pfs-command.html" },
    { "source": "/blog-47-steps", "destination": "/blog-47-steps.html" },
    { "source": "/blog-contract-types", "destination": "/blog-contract-types.html" },
    { "source": "/blog-cost-calculator", "destination": "/blog-cost-calculator.html" },
    { "source": "/blog-neighborhood-guide", "destination": "/blog-neighborhood-guide.html" },
    { "source": "/blog-scam-bible", "destination": "/blog-scam-bible.html" },
    { "source": "/blog-tenant-rights", "destination": "/blog-tenant-rights.html" },
    { "source": "/blog-visa-residency", "destination": "/blog-visa-residency.html" },
    { "source": "/canone", "destination": "/canone.html" },
    { "source": "/match", "destination": "/match.html" },
    { "source": "/pass-studio", "destination": "/pass-studio.html" },
    { "source": "/pass-demo", "destination": "/pass-demo.html" },
    { "source": "/underwriting", "destination": "/underwriting.html" },
    { "source": "/compliance", "destination": "/compliance.html" },
    { "source": "/relet", "destination": "/relet.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(self), interest-cohort=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "X-DNS-Prefetch-Control", "value": "on" },
        { "key": "Content-Security-Policy-Report-Only", "value": "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; form-action 'self' https://api.web3forms.com; script-src 'self' 'unsafe-inline' https://www.gstatic.com https://*.googleapis.com https://www.googletagmanager.com https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://js.stripe.com https://unpkg.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.jsdelivr.net https://unpkg.com; font-src 'self' data: https://fonts.gstatic.com https://cdn.jsdelivr.net; img-src 'self' data: blob: https:; connect-src 'self' https://*.googleapis.com https://*.firebaseapp.com https://*.firebaseio.com https://*.firebasestorage.app https://api.emailjs.com https://api.stripe.com https://www.google-analytics.com https://*.analytics.google.com https://region1.google-analytics.com https://www.googletagmanager.com https://api.web3forms.com https://i.imgur.com https://nominatim.openstreetmap.org https://api.ipify.org https://api.anthropic.com https://corsproxy.io https://api.codetabs.com https://thingproxy.freeboard.io https://cors.eu.org https://api.allorigins.win; frame-src 'self' https://js.stripe.com https://hooks.stripe.com https://www.youtube.com https://www.google.com https://maps.google.com https://boom-property-dashboards.firebaseapp.com; worker-src 'self' blob:; manifest-src 'self'; upgrade-insecure-requests" }
      ]
    },
    {
      "source": "/(portal|admin|admin-flats|setup-firebase|seed-listings|boom-doc-parser|boom_doc_parser|cockpit-preview|pfs-command|pfs-command.html|underwriting|compliance|relet|pass-studio|portal.html|admin.html|admin-flats.html|setup-firebase.html|seed-listings.html|boom_doc_parser.html|cockpit-preview.html|underwriting.html|compliance.html|relet.html|pass-studio.html)(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive, nosnippet" },
        { "key": "Cache-Control", "value": "private, no-store, max-age=0" }
      ]
    },
    {
      "source": "/(dashboard|client-portal|owner-dashboard|tenant-registration|login|sign|onboarding|pre-arrival|precheck|thank-you|proppass|pass-delivery|form-tenant|form-landlord)(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, follow" }
      ]
    },
    {
      "source": "/(.*)\\.(png|jpg|jpeg|svg|webp|avif|ico|woff|woff2|ttf|otf)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=86400" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ],
  "functions": {
    "api/reminder-cron.js": {
      "maxDuration": 60
    },
    "api/listing.js": {
      "includeFiles": "apartment-detail.html"
    },
    "api/geocode-all.js": {
      "maxDuration": 60
    },
    "api/magic-sign/submit.js": {
      "maxDuration": 60
    },
    "api/sign/custom/submit.js": {
      "maxDuration": 60
    },
    "api/pfs/scan-inbox.js": {
      "maxDuration": 60
    },
    "api/pfs/scan-market.js": {
      "maxDuration": 60
    },
    "api/pfs/sync-searches.js": {
      "maxDuration": 60
    },
    "api/pfs/brief.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/reminder-cron",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/telegram/notify-pending",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/pfs/scan-inbox",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/pfs/scan-market",
      "schedule": "7,37 * * * *"
    },
    {
      "path": "/api/pfs/sync-searches",
      "schedule": "15 5 * * *"
    },
    {
      "path": "/api/pfs/brief",
      "schedule": "0 6 * * *"
    }
  ]
}
