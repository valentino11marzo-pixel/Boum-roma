{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "installCommand": "npm ci",
  "images": {
    "remotePatterns": [
      {
        "protocol": "https",
        "hostname": "i.imgur.com"
      },
      {
        "protocol": "https",
        "hostname": "imgur.com"
      },
      {
        "protocol": "https",
        "hostname": "firebasestorage.googleapis.com"
      },
      {
        "protocol": "https",
        "hostname": "images.unsplash.com"
      }
    ],
    "formats": [
      "image/avif",
      "image/webp"
    ],
    "sizes": [
      320,
      480,
      640,
      768,
      828,
      1080,
      1280,
      1920
    ],
    "qualities": [
      50,
      72,
      75
    ],
    "minimumCacheTTL": 2678400
  },
