rules_version = '2';

// BOOM Roma — Firebase Storage Security Rules
// Companion to firestore.rules. Until now Storage had NO rules in the repo,
// meaning contract scans, ID documents, and payment proofs were readable/
// writable by anyone. These lock every object to the owning user + the
// admin, with landlords able to read files attached to their properties.
//
// Storage layout (verified against portal.html upload paths):
//   documents/{userId}/{timestamp}_{filename}        general doc archive
//   maintenance/{userId}/{timestamp}_{filename}       maintenance photos
//   payment-proofs/{userId}/{timestamp}_{filename}    payment receipts
//   taxpacks/{ownerId}/{year}/{filename}              generated tax bundles
//
// Role is read from Firestore users/{uid}.role via firestore.get().

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() { return request.auth != null; }
    function uid() { return request.auth.uid; }
    function role() {
      return isSignedIn()
        ? firestore.get(/databases/(default)/documents/users/$(uid())).data.role
        : '';
    }
    function isAdmin() { return role() == 'admin'; }
    function isLandlord() { return role() == 'landlord'; }

    // Size + type guards for uploads (defense against abuse / huge files).
    function validUpload() {
      return request.resource.size < 25 * 1024 * 1024  // 25 MB ceiling
        && request.resource.contentType.matches('image/.*|application/pdf|application/zip');
    }

    // ─── documents/{userId}/** ────────────────────────────────────────
    // Owner reads/writes their own folder. Admin everything. Landlords can
    // read (not write) any document folder — they may need a tenant's
    // uploaded receipt for their own property; the Firestore `documents`
    // doc-level rule is the finer gate on which ones surface in the UI.
    match /documents/{userId}/{allPaths=**} {
      allow read:  if isAdmin() || uid() == userId || isLandlord();
      allow write: if (isAdmin() || uid() == userId) && validUpload();
      allow delete: if isAdmin() || uid() == userId;
    }

    // ─── maintenance/{userId}/** ──────────────────────────────────────
    // Tenant uploads issue photos to their own folder; admin + the
    // property's landlord can view.
    match /maintenance/{userId}/{allPaths=**} {
      allow read:  if isAdmin() || uid() == userId || isLandlord();
      allow write: if (isAdmin() || uid() == userId) && validUpload();
      allow delete: if isAdmin() || uid() == userId;
    }

    // ─── payment-proofs/{userId}/** ───────────────────────────────────
    // Tenant uploads payment receipts to their own folder; admin + landlord
    // can view to reconcile.
    match /payment-proofs/{userId}/{allPaths=**} {
      allow read:  if isAdmin() || uid() == userId || isLandlord();
      allow write: if (isAdmin() || uid() == userId) && validUpload();
      allow delete: if isAdmin() || uid() == userId;
    }

    // ─── taxpacks/{ownerId}/** ────────────────────────────────────────
    // Generated tax bundles for the commercialista. Admin writes (the
    // generator runs admin-side); the owning landlord reads their own.
    match /taxpacks/{ownerId}/{allPaths=**} {
      allow read:  if isAdmin() || (isLandlord() && uid() == ownerId);
      allow write, delete: if isAdmin();
    }

    // ─── Apple Wallet pass assets / public marketing ──────────────────
    // pass-assets are static and served publicly elsewhere; nothing
    // user-generated lives here, so allow public read, admin write.
    match /pass-assets/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── property-photos/{propertyId}/** ──────────────────────────────
    // Listing gallery prepared in Photo Studio. Public read (the photos are
    // shown on public listing/apartment pages). Admin writes/deletes (the
    // studio is admin-only and properties are admin-managed); landlords read.
    match /property-photos/{propertyId}/{allPaths=**} {
      allow read:  if true;
      allow write: if isAdmin() && validUpload();
      allow delete: if isAdmin();
    }

    // ─── listings/** ──────────────────────────────────────────────────
    // Cover images for public website inventory. Public read, admin write.
    match /listings/{allPaths=**} {
      allow read:  if true;
      allow write: if isAdmin() && validUpload();
      allow delete: if isAdmin();
    }

    // ─── passes/** ────────────────────────────────────────────────────
    // Generated .pkpass files delivered via tokenized download URL. Public
    // read (URL carries an unguessable token); any signed-in user may write
    // (admin generating tenant/landlord/viewing passes; landlord generating
    // their own Partner pass). 5 MB ceiling.
    match /passes/{allPaths=**} {
      allow read:  if true;
      allow write: if isSignedIn() && request.resource.size < 5 * 1024 * 1024;
      allow delete: if isAdmin();
    }

    // ─── contracts/{contractId}/** ────────────────────────────────────
    // FES signing certificates generated server-side (api/sign/_finalize.js)
    // with the admin ID token — Storage rules apply to it, so without this
    // match every certificate upload 403s. Recipients download through the
    // tokenized ?alt=media&token= URL, which bypasses rules.
    match /contracts/{contractId}/{allPaths=**} {
      allow read, write: if isAdmin();
    }

    // ─── signRequests/{reqId}/** ──────────────────────────────────────
    // Signed tailored-PDF outputs (api/sign/custom/submit.js), uploaded with
    // the same admin ID token. Same tokenized-URL delivery for signers.
    match /signRequests/{reqId}/{allPaths=**} {
      allow read, write: if isAdmin();
    }

    // ─── Default deny ─────────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
